
# ========== LLM配置 ==========
# 使用 Gemini (推荐): 设置 LLM_PROVIDER=gemini
# 使用智谱AI (默认): 设置 LLM_PROVIDER=zhipu 或留空

# 模型提供商
LLM_PROVIDER=gemini

# Gemini 配置
GEMINI_API_KEY=你的Gemini_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# 智谱AI 配置
LLM_MODEL_ID=glm-4-flash
LLM_API_KEY=你的智谱API_KEY
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 超时时间（可选，默认120秒）
LLM_TIMEOUT=120

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志级别
LOG_LEVEL=INFO

# Unsplash API Credentials
UNSPLASH_ACCESS_KEY=""
UNSPLASH_SECRET_KEY=""

# 高德地图API配置
AMAP_API_KEY=your_amap_api_key_here